generator client {
  provider   = "prisma-client"
  output     = "../generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  PATIENT
  DOCTOR
  ADMIN
}

enum ConsultationType {
  IN_CLINIC
  ONLINE
}

enum ConversationStatus {
  ACTIVE
  CLOSED
}

enum MessageSenderRole {
  PATIENT
  DOCTOR
}

enum MessageType {
  TEXT
  IMAGE
  MIXED
}

enum SocialMediaPlatform {
  INSTAGRAM
  FACEBOOK
  TIKTOK
  YOUTUBE
  LINKEDIN
  X
  SNAPCHAT
  WEBSITE
  OTHER
}

model User {
  id                  String              @id @default(cuid())
  email               String              @unique
  name                String?
  role                UserRole            @default(PATIENT)
  dateOfBirth         String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  emailVerified       Boolean             @default(false)
  onboardingCompleted Boolean             @default(false)
  image               String?
  sessions            Session[]
  accounts            Account[]
  messageAttachments  MessageAttachment[]

  patientProfile PatientProfile?
  doctorProfile  DoctorProfile?

  patientConsultationBookings       ConsultationBooking[]        @relation("PatientConsultationBookings")
  inClinicConsultationAccesses      InClinicConsultationAccess[] @relation("PatientInClinicAccesses")
  onlineConsultationAccesses        OnlineConsultationAccess[]   @relation("PatientOnlineAccesses")
  patientConsultationRefundRequests ConsultationRefundRequest[]  @relation("PatientConsultationRefundRequests")

  patientConversations Conversation[] @relation("PatientConversations")
  sentMessages         Message[]      @relation("MessageSender")

  doctorReviews     Review[]           @relation("PatientDoctorReviews")
  reviewInvitations ReviewInvitation[] @relation("PatientReviewInvitations")

  @@index([role])
  @@map("user")
}

model DoctorProfile {
  id     String  @id @default(cuid())
  userId String  @unique
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug   String? @unique

  avatar            String?
  yearsOfExperience Float?
  clinicName        String
  clinicBanner      String?
  // Transitional legacy arrays. Keep these during the expand/backfill/dual-write
  // migration and remove them only after relational-data parity is verified.
  specialtyIds      String[]
  subcategoryIds    String[]
  procedureIds      String[]
  subzoneIds        String[]
  topThree          String[]
  workAddress       String
  city              String?
  country           String?
  zipCode           String?
  workLatitude      Float?
  workLongitude     Float?
  googlePlaceId     String?
  currency          String   @default("eur")
  RPPS              String?

  inClinicPrice     Float?
  onlineConsulPrice Float?
  onlineActive      Boolean @default(true)
  inClinicLink      String?

  stripeSubscriptionId            String?
  stripeSubscriptionStatus        String?
  stripeCustomerId                String?
  subscriptionCurrentPeriodEnd    DateTime?
  subscriptionPlan                String?   @default("free")
  stripeConnectAccountId          String?
  stripeConnectOnboardingComplete Boolean   @default(false)
  stripeConnectChargesEnabled     Boolean   @default(false)
  stripeConnectPayoutsEnabled     Boolean   @default(false)

  bookingLinks      String[]
  googleRating      Float?
  googleReviewCount Int?
  googleMapsUri     String?

  otherSpecialtyText String?

  socialMediaLinks DoctorSocialMedia[]
  specialties      DoctorSpecialty[]
  categories       DoctorCategory[]
  subcategories    DoctorSubcategory[]
  procedures       DoctorProcedure[]

  consultationBookings         ConsultationBooking[]
  inClinicConsultationAccesses InClinicConsultationAccess[]
  onlineConsultationAccesses   OnlineConsultationAccess[]
  consultationRefundRequests   ConsultationRefundRequest[]

  conversations Conversation[] @relation("DoctorConversations")

  instagramReels InstagramReel[]

  reviews           Review[]
  reviewInvitations ReviewInvitation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([city])
  @@index([country, city])
  @@index([workLatitude, workLongitude])
  @@map("doctor_profile")
}

/// Supported catalogue locales (for example "en" and "fr").
/// Locale codes should be stored as lowercase BCP 47 language tags.
model CatalogLocale {
  code        String  @id @db.VarChar(35)
  displayName String
  isDefault   Boolean @default(false)
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  specialtyGroupTranslations SpecialtyGroupTranslation[]
  specialtyTranslations      SpecialtyTranslation[]
  categoryTranslations       CategoryTranslation[]
  subcategoryTranslations    SubcategoryTranslation[]
  procedureTranslations      ProcedureTranslation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@map("catalog_locale")
}

/// Presentation grouping used by the doctor-onboarding specialty picker.
model SpecialtyGroup {
  id        String  @id
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  translations SpecialtyGroupTranslation[]
  specialties  Specialty[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@map("specialty_group")
}

model SpecialtyGroupTranslation {
  specialtyGroupId String
  localeCode       String @db.VarChar(35)
  name             String

  specialtyGroup SpecialtyGroup @relation(fields: [specialtyGroupId], references: [id], onDelete: Cascade)
  locale         CatalogLocale  @relation(fields: [localeCode], references: [code], onDelete: Restrict)

  @@id([specialtyGroupId, localeCode])
  @@index([localeCode, name])
  @@map("specialty_group_translation")
}

model Specialty {
  /// Preserve the existing doctorCatalogue ID.
  id               String  @id
  specialtyGroupId String
  icon             String?
  sortOrder        Int     @default(0)
  isActive         Boolean @default(true)

  specialtyGroup SpecialtyGroup         @relation(fields: [specialtyGroupId], references: [id], onDelete: Restrict)
  translations   SpecialtyTranslation[]
  categoryLinks  SpecialtyCategory[]
  doctors        DoctorSpecialty[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([specialtyGroupId, sortOrder])
  @@index([isActive, sortOrder])
  @@map("specialty")
}

model SpecialtyTranslation {
  specialtyId String
  localeCode  String  @db.VarChar(35)
  name        String
  description String?

  specialty Specialty     @relation(fields: [specialtyId], references: [id], onDelete: Cascade)
  locale    CatalogLocale @relation(fields: [localeCode], references: [code], onDelete: Restrict)

  @@id([specialtyId, localeCode])
  @@index([localeCode, name])
  @@map("specialty_translation")
}

model Category {
  /// Preserve the existing doctorCatalogue ID.
  id             String  @id
  slug           String  @unique
  href           String?
  homeImage      String?
  dashboardImage String?
  icon           String?
  sortOrder      Int     @default(0)
  isActive       Boolean @default(true)

  translations   CategoryTranslation[]
  specialtyLinks SpecialtyCategory[]
  subcategories  Subcategory[]
  doctors        DoctorCategory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@map("category")
}

model CategoryTranslation {
  categoryId  String
  localeCode  String  @db.VarChar(35)
  name        String
  description String?

  category Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  locale   CatalogLocale @relation(fields: [localeCode], references: [code], onDelete: Restrict)

  @@id([categoryId, localeCode])
  @@index([localeCode, name])
  @@map("category_translation")
}

/// Explicit many-to-many mapping imported from SPECIALTY_CATEGORY_MAP.
model SpecialtyCategory {
  specialtyId String
  categoryId  String
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  specialty Specialty @relation(fields: [specialtyId], references: [id], onDelete: Restrict)
  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([specialtyId, categoryId])
  @@index([categoryId, specialtyId])
  @@index([specialtyId, isActive, sortOrder])
  @@map("specialty_category")
}

model Subcategory {
  /// Preserve the existing doctorCatalogue ID.
  id         String  @id
  categoryId String
  sortOrder  Int     @default(0)
  isActive   Boolean @default(true)

  category       Category                 @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  translations   SubcategoryTranslation[]
  procedureLinks ProcedureSubcategory[]
  doctors        DoctorSubcategory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId, sortOrder])
  @@index([isActive, sortOrder])
  @@map("subcategory")
}

model SubcategoryTranslation {
  subcategoryId String
  localeCode    String  @db.VarChar(35)
  name          String
  description   String?

  subcategory Subcategory   @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)
  locale      CatalogLocale @relation(fields: [localeCode], references: [code], onDelete: Restrict)

  @@id([subcategoryId, localeCode])
  @@index([localeCode, name])
  @@map("subcategory_translation")
}

model Procedure {
  /// Preserve the existing doctorCatalogue ID.
  id       String  @id
  isActive Boolean @default(true)

  translations     ProcedureTranslation[]
  subcategoryLinks ProcedureSubcategory[]
  doctors          DoctorProcedure[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@map("procedure")
}

model ProcedureTranslation {
  procedureId String
  localeCode  String  @db.VarChar(35)
  name        String
  description String?

  procedure Procedure     @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  locale    CatalogLocale @relation(fields: [localeCode], references: [code], onDelete: Restrict)

  @@id([procedureId, localeCode])
  @@index([localeCode, name])
  @@map("procedure_translation")
}

model DoctorCategory {
  doctorProfileId String
  categoryId      String
  position        Int @default(0)

  doctorProfile DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
  category      Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([doctorProfileId, categoryId])
  @@index([categoryId, doctorProfileId])
  @@index([doctorProfileId, position])
  @@map("doctor_category")
}

/// Procedures are many-to-many with subcategories because the current catalogue
/// reuses bodytite, subcutaneous_rf, and sclerotherapy under multiple parents.
model ProcedureSubcategory {
  procedureId   String
  subcategoryId String
  sortOrder     Int     @default(0)
  isActive      Boolean @default(true)

  procedure   Procedure   @relation(fields: [procedureId], references: [id], onDelete: Restrict)
  subcategory Subcategory @relation(fields: [subcategoryId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([subcategoryId, procedureId])
  @@index([procedureId, subcategoryId])
  @@index([subcategoryId, isActive, sortOrder])
  @@map("procedure_subcategory")
}

model DoctorSpecialty {
  doctorProfileId String
  specialtyId     String
  position        Int    @default(0)

  doctorProfile DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
  specialty     Specialty     @relation(fields: [specialtyId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([doctorProfileId, specialtyId])
  @@index([specialtyId, doctorProfileId])
  @@index([doctorProfileId, position])
  @@map("doctor_specialty")
}

model DoctorSubcategory {
  doctorProfileId String
  subcategoryId   String
  position        Int    @default(0)

  doctorProfile DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
  subcategory   Subcategory   @relation(fields: [subcategoryId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([doctorProfileId, subcategoryId])
  @@index([subcategoryId, doctorProfileId])
  @@index([doctorProfileId, position])
  @@map("doctor_subcategory")
}

model DoctorProcedure {
  doctorProfileId String
  procedureId     String
  position        Int    @default(0)
  topRank         Int?

  /// Doctor-specific price. Decimal avoids floating-point errors for money.
  /// A null value means that this doctor has not published a price.
  price Decimal? @db.Decimal(12, 2)

  doctorProfile DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
  procedure     Procedure     @relation(fields: [procedureId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([doctorProfileId, procedureId])
  @@unique([doctorProfileId, topRank])
  @@index([procedureId, doctorProfileId])
  @@index([doctorProfileId, position])
  @@map("doctor_procedure")
}

model DoctorSocialMedia {
  id String @id @default(cuid())

  doctorProfileId String
  doctorProfile   DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)

  platform SocialMediaPlatform
  url      String

  /// Optional username such as @estheticdoctor.
  username String?

  /// Useful for OTHER or custom display names.
  label String?

  isVisible Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([doctorProfileId, platform, url])
  @@index([doctorProfileId])
  @@index([doctorProfileId, isVisible, sortOrder])
  @@map("doctor_social_media")
}

model PatientProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  avatar      String?
  gender      String?
  phoneNumber String?

  city          String?
  country       String?
  zipCode       String?
  address       String?
  latitude      Float?
  longitude     Float?
  googlePlaceId String?
  favorite      String[]

  preferredConsultationType String? // "in_clinic" | "online"
  preferredLanguage         String?

  stripeCustomerId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("patient_profile")
}

model ConsultationBooking {
  id String @id @default(cuid())

  patientUserId String
  patientUser   User   @relation("PatientConsultationBookings", fields: [patientUserId], references: [id], onDelete: Cascade)

  doctorProfileId String
  doctorProfile   DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)

  consultationType ConsultationType

  amount       Int
  platformFee  Int
  doctorAmount Int
  currency     String @default("eur")

  stripeCheckoutSessionId String? @unique
  stripePaymentIntentId   String? @unique
  stripeChargeId          String?
  stripeTransferId        String?

  paymentConfirmedEmailSentAt  DateTime?
  paymentProcessingEmailSentAt DateTime?
  paymentFailedEmailSentAt     DateTime?

  status String @default("pending") // pending | paid | cancelled | refunded | failed

  paidAt      DateTime?
  cancelledAt DateTime?
  refundedAt  DateTime?

  inClinicAccess InClinicConsultationAccess?
  onlineAccess   OnlineConsultationAccess?

  refundRequests ConsultationRefundRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientUserId])
  @@index([doctorProfileId])
  @@index([consultationType])
  @@index([status])
  @@map("consultation_booking")
}

model ConsultationRefundRequest {
  id String @id @default(cuid())

  bookingId String
  booking   ConsultationBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  patientUserId String
  patientUser   User   @relation("PatientConsultationRefundRequests", fields: [patientUserId], references: [id], onDelete: Cascade)

  doctorProfileId String
  doctorProfile   DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)

  reason    String
  status    String  @default("pending") // pending | approved | rejected | refunded
  adminNote String?

  createdAt  DateTime  @default(now())
  reviewedAt DateTime?
  refundedAt DateTime?

  @@index([bookingId])
  @@index([patientUserId])
  @@index([doctorProfileId])
  @@index([status])
  @@map("consultation_refund_request")
}

model InClinicConsultationAccess {
  id String @id @default(cuid())

  bookingId String              @unique
  booking   ConsultationBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  patientUserId String
  patientUser   User   @relation("PatientInClinicAccesses", fields: [patientUserId], references: [id], onDelete: Cascade)

  doctorProfileId String
  doctorProfile   DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)

  approvedToView Boolean @default(false)

  purchasedAt DateTime  @default(now())
  approvedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientUserId])
  @@index([doctorProfileId])
  @@index([approvedToView])
  @@map("in_clinic_consultation_access")
}

model OnlineConsultationAccess {
  id String @id @default(cuid())

  bookingId String              @unique
  booking   ConsultationBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  patientUserId String
  patientUser   User   @relation("PatientOnlineAccesses", fields: [patientUserId], references: [id], onDelete: Cascade)

  doctorProfileId String
  doctorProfile   DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)

  activeChat Boolean @default(false)

  conversation Conversation?

  purchasedAt DateTime  @default(now())
  activatedAt DateTime?
  closedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientUserId])
  @@index([doctorProfileId])
  @@index([activeChat])
  @@map("online_consultation_access")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model BeforeAfterCase {
  id String @id @default(cuid())

  doctorId  String
  patientId String?

  procedure String?
  notes     String?

  title    String?
  isPublic Boolean @default(false)

  beforeImage String?
  afterImage  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([doctorId])
  @@index([patientId])
}

model Conversation {
  id String @id @default(cuid())

  onlineAccessId String                   @unique
  onlineAccess   OnlineConsultationAccess @relation(fields: [onlineAccessId], references: [id], onDelete: Cascade)

  patientUserId String
  patientUser   User   @relation("PatientConversations", fields: [patientUserId], references: [id], onDelete: Cascade)

  doctorProfileId String
  doctorProfile   DoctorProfile @relation("DoctorConversations", fields: [doctorProfileId], references: [id], onDelete: Cascade)

  status ConversationStatus @default(ACTIVE)

  lastMessageAt DateTime?
  closedAt      DateTime?

  messages    Message[]
  attachments MessageAttachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientUserId])
  @@index([doctorProfileId])
  @@index([status])
  @@index([lastMessageAt])
  @@map("conversation")
}

model Message {
  id String @id @default(cuid())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderUserId String
  senderUser   User   @relation("MessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)

  senderRole MessageSenderRole

  messageType MessageType @default(TEXT)

  // Keep nullable now because image-only messages may not have text
  ciphertext String?
  iv         String?
  authTag    String?
  keyVersion Int     @default(1)

  attachments MessageAttachment[]

  readAt    DateTime?
  editedAt  DateTime?
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conversationId])
  @@index([senderUserId])
  @@index([createdAt])
  @@map("message")
}

model MessageAttachment {
  id String @id @default(cuid())

  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  uploadedByUserId String
  uploadedByUser   User   @relation(fields: [uploadedByUserId], references: [id], onDelete: Cascade)

  objectPath  String
  fileName    String?
  contentType String
  sizeBytes   Int?

  createdAt DateTime @default(now())

  @@index([messageId])
  @@index([conversationId])
  @@index([uploadedByUserId])
  @@map("message_attachment")
}

model InstagramReel {
  id        String @id @default(cuid())
  url       String @unique
  sortOrder Int    @default(0)

  doctorProfileId String?
  doctorProfile   DoctorProfile? @relation(fields: [doctorProfileId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@index([doctorProfileId])
  @@index([doctorProfileId, sortOrder])
  @@map("instagram_reel")
}

model Review {
  id String @id @default(cuid())

  title  String
  review String
  rating Int

  patientUserId String
  patientUser   User   @relation("PatientDoctorReviews", fields: [patientUserId], references: [id], onDelete: Cascade)

  doctorProfileId String
  doctorProfile   DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)

  invitationId String?           @unique
  invitation   ReviewInvitation? @relation(fields: [invitationId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientUserId])
  @@index([doctorProfileId])
  @@index([doctorProfileId, createdAt])
  @@index([rating])
  @@map("review")
}

model ReviewInvitation {
  id String @id @default(cuid())

  doctorProfileId String
  doctorProfile   DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)

  // Nullable for a generic link generated without selecting a patient.
  // The first authenticated PATIENT who submits through the link claims it.
  patientUserId String?
  patientUser   User?   @relation("PatientReviewInvitations", fields: [patientUserId], references: [id], onDelete: Cascade)

  // Nullable for the same generic-link flow.
  recipientEmail String?
  tokenHash      String  @unique

  expiresAt DateTime
  sentAt    DateTime?
  usedAt    DateTime?
  revokedAt DateTime?

  review Review?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([doctorProfileId])
  @@index([patientUserId])
  @@index([recipientEmail])
  @@index([expiresAt])
  @@index([doctorProfileId, patientUserId])
  @@map("review_invitation")
}
